raw_text = "~ talk
do turn_npc_to_player(\"Sacred\")
{{green}}: Hi there. What's your name?
{{sacred}}: {{sacred}}.
{{green}}: [#expression=cheerful] What a cute name! My name is {{green}}.
{{green}}: You probably shouldn't be on your own like this. Let me take you somewhere safe.
{{sacred}}: ok.
do add_member(\"Sacred\")
=> END!


~ revisit
{{sacred}}: Am I safe now?
=> END!


~ reveal
do change_rooms(\"sea_space\", \"SacredStatue\")
=> END!"
metadata/dialogue_manager_version = "3.10.1"
