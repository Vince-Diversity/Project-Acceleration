raw_text = "~ find_skates
{{green}}: (Maybe I can recreate this frozen equipment.)
do animate_player(Names.focus_anim, \"create\")
=> END!

~ create
do wait(1)
do set_player_exhibit_anim(\"ice_skates\")
[color=yellow]Obtained the {{skates}}![/color]
do add_item(\"ice_skates\")
do set_thing_state(\"IceSkates\", \"thing_static_state\")
do set_player_anim(\"down\")
=> END!
"
metadata/dialogue_manager_version = "3.4.0"
